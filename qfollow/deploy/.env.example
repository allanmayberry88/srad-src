# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_PUBSUB_TOPIC=projects/xxxx/topics/gmail-notifications

# Slack
SLACK_BOT_TOKEN=xoxb-xxxx
SLACK_SIGNING_SECRET=

# Anthropic (production LLM calls)
ANTHROPIC_API_KEY=sk-ant-xxxx

# Encryption key for OAuth tokens at rest
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# n8n internal credential encryption (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=

# n8n public API key — Settings → n8n API in the n8n UI. Used by n8n-mcp.
N8N_API_KEY=

# Tunnel (dev/dogfood — replace with VPS details for production)
WEBHOOK_BASE_URL=https://xxxx.trycloudflare.com
